# 应用配置
APP_NAME=货币基金折价套利监控系统
DEBUG=false

# 告警阈值（年化收益率百分比）
ALERT_THRESHOLD=3.0

# 数据刷新间隔（秒）
REFRESH_INTERVAL=60

# ==================== 通知配置 ====================

# Bark (iOS推送)
BARK_URL=https://api.day.app/YOUR_KEY

# Server酱 (微信推送)
SERVERCHAN_KEY=SCTxxxxxxxx

# 邮件通知
EMAIL_SMTP=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASSWORD=your_password
EMAIL_TO=recipient@email.com

# ==================== 云服务商配置 ====================

# 阿里云 (Serverless/函数计算)
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_ACCOUNT_ID=

# 腾讯云 (SCF云函数)
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_APP_ID=

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0